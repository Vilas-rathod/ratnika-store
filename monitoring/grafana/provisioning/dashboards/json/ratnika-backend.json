{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Ratnika Backend — Spring Boot",
  "uid": "ratnika-backend",
  "tags": ["ratnika", "spring-boot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "App Up",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ]
        }
      },
      "targets": [
        { "expr": "up{application=\"ratnika-backend\"}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "process_uptime_seconds{application=\"ratnika-backend\"}", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Requests / sec",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{application=\"ratnika-backend\"}[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "5xx errors / sec",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{application=\"ratnika-backend\",status=~\"5..\"}[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "HTTP request rate by status",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "sum by (status) (rate(http_server_requests_seconds_count{application=\"ratnika-backend\"}[5m]))", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "title": "Request latency (p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"ratnika-backend\"}[5m])))", "legendFormat": "p95", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "title": "JVM heap used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{application=\"ratnika-backend\",area=\"heap\"})", "legendFormat": "heap used", "refId": "A" },
        { "expr": "sum(jvm_memory_max_bytes{application=\"ratnika-backend\",area=\"heap\"})", "legendFormat": "heap max", "refId": "B" }
      ]
    },
    {
      "id": 8,
      "title": "HikariCP active connections",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "hikaricp_connections_active{application=\"ratnika-backend\"}", "legendFormat": "active", "refId": "A" },
        { "expr": "hikaricp_connections_idle{application=\"ratnika-backend\"}", "legendFormat": "idle", "refId": "B" }
      ]
    }
  ]
}
