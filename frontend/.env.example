# ── Ratnika Frontend Environment ──────────────────────────────
# Copy to .env.local and adjust values. All variables must be
# prefixed with VITE_ to be exposed to the client bundle.

# Base URL of the Spring Boot backend REST API
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Use the built-in mock API (localStorage-backed) instead of the
# real backend. Set to "false" once the backend is running.
VITE_USE_MOCK_API=true

# Razorpay publishable key (Dashboard → Settings → API Keys)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Public app URL (used for share links / SEO)
VITE_APP_URL=http://localhost:5173
