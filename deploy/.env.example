# ── Ratnika production deploy env ────────────────────────────────
# Copy to deploy/.env and fill in real values. NEVER commit deploy/.env.
# Used by:  docker compose -f docker-compose.prod.yml --env-file deploy/.env ...

# Docker Hub image source (set by / matches the Jenkins pipeline)
DOCKERHUB_USERNAME=vilasrathod95
IMAGE_TAG=latest

# MySQL
MYSQL_DATABASE=ratnika
MYSQL_USER=ratnika
MYSQL_PASSWORD=change-me-strong-password
MYSQL_ROOT_PASSWORD=change-me-strong-root-password

# Backend
DDL_AUTO=update
CORS_ALLOWED_ORIGINS=http://localhost
FRONTEND_URL=http://localhost
# Base64-encoded 256-bit secret. Generate: openssl rand -base64 32
JWT_SECRET=change-me-base64-256-bit-secret

# Grafana admin
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me
