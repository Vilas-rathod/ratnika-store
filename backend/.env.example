# ── Ratnika Backend Environment ───────────────────────────────
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# Database (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/ratnika
DB_USERNAME=ratnika
DB_PASSWORD=ratnika

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — generate a strong base64 256-bit secret for production!
#   openssl rand -base64 32
JWT_SECRET=c2VjcmV0LWtleS1mb3ItdmVlei1jYXJ0LWNoYW5nZS1pbi1wcm9kdWN0aW9uLTEyMzQ1Njc4OTA=
JWT_ACCESS_EXP=900000
JWT_REFRESH_EXP=604800000

# Mail (dev: MailHog on 1025). For prod use real SMTP.
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

# CORS (frontend origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
FRONTEND_URL=http://localhost:5173

# Razorpay
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=changeme

# Storage: local | cloudinary | s3 | minio
STORAGE_PROVIDER=local
STORAGE_PUBLIC_URL=http://localhost:8080/uploads
